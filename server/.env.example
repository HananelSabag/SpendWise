# Example Environment Variables - Copy to .env and fill in real values
# DO NOT put real passwords here!

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Pool Settings
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# Timezone
DEFAULT_TIMEZONE=Asia/Jerusalem

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME=SpendWise
CLIENT_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# File Upload
UPLOAD_SIZE_LIMIT=5242880

# Scheduler
ENABLE_SCHEDULER=true

# ─── Bank Connect (spendwise-agent) ─────────────────────────────
# BANK_AGENT_KEY: shared secret for the sync agent's job-queue access.
# Must match BANK_AGENT_KEY in spendwise-agent/.env. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BANK_AGENT_KEY=replace-with-a-long-random-secret

# BANK_AGENT_PUBLIC_KEY: the agent's X25519 public key (base64). Browsers
# use it to encrypt bank credentials so only the agent machine can decrypt
# them. Produced by: npm run keys  (in the spendwise-agent repo).
BANK_AGENT_PUBLIC_KEY=

# ─── Legacy standalone path (spendwise-agent "standalone" mode) ──
# Optional. Only needed if you run the agent's standalone mode instead of
# the Bank Connect queue. Must match BANK_SYNC_API_KEY in the agent .env.
BANK_SYNC_API_KEY=replace-with-a-long-random-secret
# Whitelist of user IDs the legacy /bank-sync endpoint may write to.
ALLOWED_HOUSEHOLD_IDS=34
