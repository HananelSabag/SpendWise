# Example Environment Variables - Copy to .env and fill in real values
# DO NOT put real passwords here!

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Pool Settings
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here

# Timezone
DEFAULT_TIMEZONE=Asia/Jerusalem

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME=SpendWise
CLIENT_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# File Upload
UPLOAD_SIZE_LIMIT=5242880

# Scheduler
ENABLE_SCHEDULER=true

# Bank Sync (bank-scraper integration)
# Must match BANK_SYNC_API_KEY in bank-scraper/.env — use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BANK_SYNC_API_KEY=replace-with-a-long-random-secret

# Whitelist of user IDs that the bank-scraper is allowed to sync to (comma-separated).
# Even if the API key leaks, only these user IDs can receive transactions.
# Leave blank to allow any user ID (not recommended for production).
ALLOWED_HOUSEHOLD_IDS=34
