# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
build/
out/

# Environment variables (CRITICAL: never commit secrets)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage
coverage/
*.lcov

# Caches
.cache/
.parcel-cache/
.vite/
.eslintcache
.npm

# PWA service worker (auto-generated)
sw.*
workbox-*.js

# Test output
test-results/
playwright-report/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor directories
.idea/
*.sublime-project
*.sublime-workspace

# VSCode (keep shared config, ignore local overrides)
.vscode/
!.vscode/extensions.json

# TypeScript
*.tsbuildinfo

# Package manager lock files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Temporary files
*.tmp
*.temp
*.bak
*.orig
