{
  "name": "spendwise-client",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:basic": "vite --open",
    "dev:clean": "vite",
    "dev:admin": "vite --mode admin",
    "dev:analytics": "vite --mode analytics",
    "dev:mobile": "vite --host 0.0.0.0 --port 5173",
    "dev:network": "vite --host --port 5173",
    "dev:open": "vite --host 0.0.0.0 --port 5173 --open",
    "build": "vite build",
    "build:admin": "vite build --mode admin",
    "build:analytics": "vite build --mode analytics",
    "preview": "vite preview",
    "preview:mobile": "vite preview --host 0.0.0.0 --port 4173",
    "performance": "npm run build && npx lighthouse http://localhost:4173 --view",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/query-sync-storage-persister": "^5.79.0",
    "@tanstack/react-query": "^5.51.1",
    "@tanstack/react-query-devtools": "^5.51.1",
    "@tanstack/react-query-persist-client": "^5.79.0",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.20.1",
    "immer": "^10.0.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.28.1",
    "tailwind-merge": "^2.4.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.49.0",
    "typescript": "^5.2.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "npm@10.2.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0 <25.0.0"
  }
}
